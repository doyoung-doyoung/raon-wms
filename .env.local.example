# =============================================
# RAON WMS — 환경변수 설정 파일
# 이 파일을 복사해서 .env.local 로 저장하고
# 각 값을 채워넣으세요
# =============================================

# --- NextAuth ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=여기에_openssl_rand_-base64_32_결과_붙여넣기

# --- Google OAuth (Google Cloud Console에서 복사) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- 이사(승인자) 이메일 ---
ADMIN_EMAIL=이사님_구글이메일@gmail.com

# --- 회사 정보 ---
COMPANY_NAME=RAON
COMPANY_NAME_FULL=RAON Co., Ltd.
COMPANY_ADDRESS=
COMPANY_TAX_ID=
COMPANY_PHONE=
COMPANY_EMAIL=

# --- Google Sheets ID (시트 만든 후 URL에서 복사) ---
# 예: https://docs.google.com/spreadsheets/d/[이 부분]/edit
SHEETS_EMPLOYEES_ID=
SHEETS_LEAVES_ID=
SHEETS_ATTENDANCE_ID=
SHEETS_DOCUMENTS_ID=
SHEETS_INVOICES_ID=
SHEETS_PARTNERS_ID=
SHEETS_EXPENSES_ID=

# --- Google Drive 폴더 ID ---
DRIVE_ROOT_FOLDER_ID=
DRIVE_DOCUMENTS_FOLDER_ID=
DRIVE_CONTRACTS_FOLDER_ID=
DRIVE_PAYSLIPS_FOLDER_ID=
DRIVE_LEAVE_FORMS_FOLDER_ID=
DRIVE_INVOICES_FOLDER_ID=
DRIVE_ARCHIVE_FOLDER_ID=
DRIVE_SIGNATURES_FOLDER_ID=
DRIVE_RECEIPTS_FOLDER_ID=

# --- 서비스 계정 (service-account.json 파일 경로) ---
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./service-account.json

# Google Sheets — 경고장 DB (Warnings)
SHEETS_WARNINGS_ID=
# 리포트 자동발송 시스템 키
REPORT_SYSTEM_KEY=
